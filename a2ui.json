{
  "kind": "A2uiMessage",
  "version": "1.0",
  "surfaceUpdate": {
    "surfaceId": "product_card_001",
    "dataModel": {
      "productName": "极简智能手表",
      "price": "￥1999",
      "isStocked": true
    },
    "components": [
      {
        "id": "root_container",
        "type": "container",
        "props": {
          "padding": 16,
          "backgroundColor": "#F5F5F5",
          "borderRadius": 12
        },
        "children": [
          {
            "id": "header_image",
            "type": "image",
            "props": {
              "url": "https://example.com/watch.jpg",
              "height": 200,
              "fit": "cover"
            }
          },
          {
            "id": "title_text",
            "type": "text",
            "props": {
              "value": "${data.productName}",
              "fontSize": 20,
              "fontWeight": "bold",
              "color": "#333333"
            }
          },
          {
            "id": "price_tag",
            "type": "text",
            "props": {
              "value": "${data.price}",
              "color": "#FF4400",
              "fontSize": 18
            }
          },
          {
            "id": "buy_button",
            "type": "button",
            "props": {
              "label": "立即购买",
              "variant": "filled",
              "enabled": "${data.isStocked}"
            },
            "events": {
              "onTap": {
                "action": "call_tool",
                "toolName": "process_purchase",
                "parameters": {
                  "id": "watch_001"
                }
              }
            }
          }
        ]
      }
    ]
  }
}
